# Copy this file to .env and fill in your values.
# The app works out of the box without any of these set (uses SQLite).

# Django
DJANGO_SECRET_KEY=your-secret-key-here
DJANGO_DEBUG=true
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost

# ── PostgreSQL (option A — single URL) ────────────────────────
# DATABASE_URL=postgres://user:password@localhost:5432/djorm

# ── PostgreSQL (option B — individual vars) ───────────────────
# DB_ENGINE=django.db.backends.postgresql
# DB_NAME=djorm
# DB_USER=postgres
# DB_PASSWORD=secret
# DB_HOST=localhost
# DB_PORT=5432
